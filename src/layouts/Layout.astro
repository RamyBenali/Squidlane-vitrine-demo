---
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SquidLane — La passerelle de paiement pensée pour les marchands sérieux',
  description = "SquidLane est le processeur de paiement sélectif qui protège vos revenus : liens de paiement instantanés, checkout sur-mesure, support humain. Pas de suspensions surprises, pas de fonds gelés.",
} = Astro.props;
---

<!doctype html>
<html lang="fr" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07080f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.svg" />

    <!-- Fonts: Inter (charte SquidLane) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <slot />

    <script>
      import { initAnimations } from '../scripts/animations';
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimations);
      } else {
        initAnimations();
      }
    </script>
  </body>
</html>
