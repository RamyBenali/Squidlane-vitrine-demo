---
import Icon from './Icon.astro';
import PaymentMarks from './PaymentMarks.astro';
import { getContent, CHECKOUT_DEMO, type Lang } from '../i18n/content';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = getContent(lang).features;
---

<section class="section features" id="features">
  <div class="container">
    <div class="features__head" data-reveal>
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>
        {t.title.map((l, i) => (
          <>
            {'accent' in l ? <span class="accent-word">{l.text}</span> : l.text}
            {i < t.title.length - 1 && <br />}
          </>
        ))}
      </h2>
      <p class="muted">{t.lead}</p>
    </div>

    <div class="bento" data-reveal-group>
      <!-- Carte large : liens de paiement -->
      <article class="bento__card bento__card--wide" data-reveal-item>
        <div class="bento__icon"><Icon name="link" size={22} /></div>
        <h3>{t.linkTitle}</h3>
        <p class="muted">{t.linkText}</p>
        <div class="bento__demo">
          <code>theclub.squidlane.com/buy/<span>offr_fv9_Sn8npo</span></code>
          <button class="bento__copy" data-copy={CHECKOUT_DEMO} data-copied={t.copied}>
            <Icon name="copy" size={14} />{t.copy}
          </button>
        </div>
      </article>

      <!-- Checkout custom -->
      <article class="bento__card" data-reveal-item>
        <div class="bento__icon"><Icon name="cart" size={22} /></div>
        <h3>{t.checkoutTitle}</h3>
        <p class="muted">{t.checkoutText}</p>
        <a href={CHECKOUT_DEMO} target="_blank" rel="noopener" class="bento__link">
          {t.seeCheckout}
          <Icon name="arrowRight" size={15} />
        </a>
      </article>

      <!-- Moyens de paiement -->
      <article class="bento__card" data-reveal-item>
        <div class="bento__icon"><Icon name="card" size={22} /></div>
        <h3>{t.methodsTitle}</h3>
        <p class="muted">{t.methodsText}</p>
        <PaymentMarks brands={['visa', 'mastercard', 'amex', 'applepay']} />
      </article>

      <!-- Multi-devises -->
      <article class="bento__card" data-reveal-item>
        <div class="bento__icon"><Icon name="globe" size={22} /></div>
        <h3>{t.currenciesTitle}</h3>
        <p class="muted">{t.currenciesText}</p>
      </article>

      <!-- Gestion marchand -->
      <article class="bento__card" data-reveal-item>
        <div class="bento__icon"><Icon name="dash" size={22} /></div>
        <h3>{t.manageTitle}</h3>
        <p class="muted">{t.manageText}</p>
      </article>

      <!-- Protection (large) -->
      <article class="bento__card bento__card--accent bento__card--wide" data-reveal-item>
        <div class="bento__icon"><Icon name="shieldCheck" size={22} /></div>
        <h3>{t.protectTitle}</h3>
        <p class="muted">{t.protectText}</p>
      </article>
    </div>
  </div>
</section>

<style>
  .features__head {
    max-width: 640px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .features__head h2 {
    font-size: var(--fs-h2);
    margin-bottom: 1rem;
  }
  .features__head p {
    font-size: var(--fs-lead);
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .bento__card {
    position: relative;
    padding: 1.8rem;
    border-radius: var(--radius);
    background: var(--surface-solid);
    border: 1px solid var(--border-card);
    overflow: hidden;
    transition: transform 0.4s var(--ease-out), border-color 0.4s var(--ease-out),
      box-shadow 0.4s var(--ease-out);
  }
  .bento__card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, 0.5);
  }
  .bento__card--wide {
    grid-column: span 2;
  }
  .bento__card--accent {
    background: var(--ink-850);
    border-color: rgba(236, 45, 136, 0.28);
  }

  .bento__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--surface-solid-2);
    color: var(--indigo-400);
    margin-bottom: 1.2rem;
  }
  .bento__icon :global(svg) {
    width: 22px;
    height: 22px;
  }
  .bento__card h3 {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }
  .bento__card p {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-300);
  }
  .bento__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.2rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--indigo-400);
    transition: gap 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }
  .bento__link:hover {
    gap: 0.7rem;
    color: var(--indigo-300);
  }

  .bento__demo {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.4rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: var(--ink-950);
    border: 1px solid var(--border);
  }
  .bento__demo code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.88rem;
    color: var(--text-300);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bento__copy {
    flex-shrink: 0;
  }
  .bento__demo code span {
    color: var(--indigo-300);
  }
  .bento__copy {
    font-size: 0.8rem;
    font-weight: 600;
    background: none;
    border: none;
    color: var(--indigo-400);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
  }

  @media (max-width: 860px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
    .bento__card--wide {
      grid-column: span 2;
    }
  }
  @media (max-width: 560px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento__card--wide {
      grid-column: span 1;
    }
  }
</style>
