---
import Icon from './Icon.astro';

const tracks = [
  {
    label: 'SaaS & produits digitaux',
    icon: 'monitor',
    steps: [
      { when: 'Au démarrage', delay: 7, note: 'Versements gratuits' },
      { when: 'Après 1 mois', delay: 5, note: 'Négociable selon activité', best: true },
    ],
  },
  {
    label: 'E-commerce',
    icon: 'package',
    steps: [
      { when: 'Après 15 jours', delay: 5, note: 'Versements gratuits' },
      { when: 'Après 1 mois', delay: 3, note: 'Versements gratuits', best: true },
    ],
  },
];
---

<section class="section payouts" id="payouts">
  <div class="container">
    <div class="payouts__head" data-reveal>
      <span class="eyebrow">Versements</span>
      <h2>Votre trésorerie,<br /><span class="accent-word">de plus en plus rapide.</span></h2>
      <p class="muted">
        Des versements gratuits et prévisibles, qui s’accélèrent à mesure que votre
        historique se construit. Besoin de vos fonds tout de suite&nbsp;?
        Le retrait express est là.
      </p>
    </div>

    <div class="payouts__grid" data-reveal-group>
      {tracks.map((track) => (
        <article class="track" data-reveal-item>
          <header class="track__head">
            <span class="track__icon"><Icon name={track.icon} /></span>
            <h3>{track.label}</h3>
          </header>
          <div class="track__line">
            <svg class="track__svg" width="2" height="100%" viewBox="0 0 2 100" preserveAspectRatio="none" aria-hidden="true">
              <path class="track__path" d="M1 0 V100" stroke="var(--indigo-500)" stroke-width="2" fill="none"/>
            </svg>
            {track.steps.map((s) => (
              <div class={`milestone ${s.best ? 'milestone--best' : ''}`}>
                <span class="milestone__dot"></span>
                <span class="milestone__when muted">{s.when}</span>
                <span class="milestone__delay" data-count={s.delay} data-suffix=" jours">{s.delay} jours</span>
                <span class="milestone__note muted">{s.note}</span>
              </div>
            ))}
          </div>
        </article>
      ))}

      <article class="track track--express" data-reveal-item>
        <header class="track__head">
          <span class="track__icon track__icon--express"><Icon name="zap" /></span>
          <h3>Retrait express</h3>
        </header>
        <p class="track__express-text">
          Besoin de liquidités immédiatement&nbsp;? Déclenchez un versement instantané à tout
          moment.
        </p>
        <div class="track__express-fee">
          <strong data-count="1" data-suffix="%">1%</strong>
          <span class="muted">de frais sur le montant retiré</span>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .payouts__head {
    max-width: 620px;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .payouts__head h2 {
    font-size: var(--fs-h2);
    margin-bottom: 1rem;
  }
  .payouts__head p {
    font-size: var(--fs-lead);
  }

  .payouts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 0.85fr;
    gap: 1.1rem;
  }
  .track {
    padding: 1.8rem;
    border-radius: var(--radius);
    background: var(--ink-900);
    border: 1px solid var(--border);
    transition: transform 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
  }
  .track:hover {
    transform: translateY(-5px);
    border-color: var(--border-strong);
  }
  .track__head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.6rem;
  }
  .track__icon {
    display: inline-flex;
    color: var(--indigo-400);
  }
  .track__icon--express {
    color: var(--cyan-400);
  }
  .track__head h3 {
    font-size: var(--fs-h3);
  }

  .track__line {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding-left: 1.4rem;
  }
  .track__svg {
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    height: auto;
  }
  /* stroke via CSS : var() n'est pas fiable en attribut de présentation SVG */
  .track__path {
    stroke: var(--indigo-500);
  }
  .milestone {
    position: relative;
    display: grid;
    gap: 0.15rem;
  }
  .milestone__dot {
    position: absolute;
    left: -1.4rem;
    top: 5px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-800);
    border: 2px solid var(--indigo-500);
  }
  .milestone--best .milestone__dot {
    background: var(--indigo-500);
    box-shadow: 0 0 0 5px rgba(236, 45, 136, 0.18);
  }
  .milestone__when {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-400);
  }
  .milestone__delay {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-100);
    letter-spacing: -0.02em;
  }
  .milestone--best .milestone__delay {
    color: var(--indigo-300);
  }
  .milestone__note {
    font-size: 0.85rem;
    color: var(--text-300);
  }

  .track--express {
    background: var(--ink-850);
    border: 1px solid var(--border);
    border-left: 2px solid var(--cyan-500);
    display: flex;
    flex-direction: column;
  }
  .track__express-text {
    font-size: 0.95rem;
    color: var(--text-300);
    margin-bottom: auto;
  }
  .track__express-fee {
    margin-top: 1.4rem;
  }
  .track__express-fee strong {
    display: block;
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--cyan-400);
    letter-spacing: -0.03em;
  }
  .track__express-fee span {
    font-size: 0.88rem;
  }

  @media (max-width: 860px) {
    .payouts__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
