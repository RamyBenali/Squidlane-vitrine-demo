---
import Icon from './Icon.astro';
import { getContent, type Lang } from '../i18n/content';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = getContent(lang).payouts;
---

<section class="section payouts" id="payouts">
  <div class="container">
    <div class="payouts__head" data-reveal>
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>
        {t.title.map((l, i) => (
          <>
            {'accent' in l ? <span class="accent-word">{l.text}</span> : l.text}
            {i < t.title.length - 1 && <br />}
          </>
        ))}
      </h2>
      <p class="muted">{t.lead}</p>
    </div>

    <div class="payouts__grid" data-reveal-group>
      {
        t.tracks.map((track) => (
          <article class="track" data-reveal-item>
            <header class="track__head">
              <span class="track__icon">
                <Icon name={track.icon} />
              </span>
              <h3>{track.label}</h3>
            </header>
            <div class="track__line">
              <svg
                class="track__svg"
                width="2"
                height="100%"
                viewBox="0 0 2 100"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path class="track__path" d="M1 0 V100" stroke-width="2" fill="none" />
              </svg>
              {track.steps.map((s) => (
                <div
                  class:list={[
                    'milestone',
                    { 'milestone--best': 'best' in s, 'milestone--express': 'express' in s },
                  ]}
                >
                  <span class="milestone__dot" />
                  <span class="milestone__when muted">{s.when}</span>
                  <span class="milestone__delay" data-count={s.n} data-suffix={t.daysUnit}>
                    {s.n}
                    {t.daysUnit}
                  </span>
                  <span class="milestone__note muted">{s.note}</span>
                </div>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .payouts__head {
    max-width: 620px;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .payouts__head h2 {
    font-size: var(--fs-h2);
    margin-bottom: 1rem;
  }
  .payouts__head p {
    font-size: var(--fs-lead);
  }

  .payouts__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.1rem;
  }
  .track {
    padding: 1.8rem;
    border-radius: var(--radius);
    background: var(--ink-900);
    border: 1px solid var(--border);
    transition: transform 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
  }
  .track:hover {
    transform: translateY(-5px);
    border-color: var(--border-strong);
  }
  .track__head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.8rem;
  }
  .track__icon {
    display: inline-flex;
    color: var(--indigo-400);
  }
  .track__head h3 {
    font-size: var(--fs-h3);
  }

  .track__line {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: 1.4rem;
  }
  .track__svg {
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    height: auto;
  }
  /* stroke via CSS : var() n'est pas fiable en attribut de présentation SVG */
  .track__path {
    stroke: var(--indigo-500);
  }
  .milestone {
    position: relative;
    display: grid;
    gap: 0.15rem;
  }
  .milestone__dot {
    position: absolute;
    left: -1.4rem;
    top: 5px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-800);
    border: 2px solid var(--indigo-500);
  }
  .milestone--best .milestone__dot {
    background: var(--indigo-500);
    box-shadow: 0 0 0 5px rgba(236, 45, 136, 0.18);
  }
  .milestone--express .milestone__dot {
    background: var(--cyan-500);
    border-color: var(--cyan-500);
  }
  .milestone__when {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-400);
  }
  .milestone__delay {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-100);
    letter-spacing: -0.02em;
  }
  .milestone--best .milestone__delay {
    color: var(--indigo-300);
  }
  .milestone--express .milestone__delay {
    color: var(--cyan-400);
  }
  .milestone__note {
    font-size: 0.85rem;
    color: var(--text-300);
  }

  @media (max-width: 720px) {
    .payouts__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
