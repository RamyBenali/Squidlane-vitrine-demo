---
import { getContent, eurTiers, usdTiers, type Lang } from '../i18n/content';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = getContent(lang).pricing;
---

<section class="section pricing" id="pricing">
  <div class="grid-bg" style="opacity:.6"></div>
  <div class="container">
    <div class="pricing__head" data-reveal>
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>
        {t.title.map((l, i) => (
          <>
            {'accent' in l ? <span class="accent-word">{l.text}</span> : l.text}
            {i < t.title.length - 1 && <br />}
          </>
        ))}
      </h2>
      <p class="muted">{t.lead}</p>

      <div class="pricing__toggle" role="tablist" aria-label="Currency" data-reveal data-delay="0.1">
        <button class="is-active" data-cur="eur" role="tab" aria-selected="true">EUR €</button>
        <button data-cur="usd" role="tab" aria-selected="false">USD $</button>
        <span class="pricing__toggle-pill" aria-hidden="true"></span>
      </div>
    </div>

    <div class="pricing__panel card" data-reveal data-cur="eur">
      <div class="pricing__hero">
        <div class="pricing__rate">
          <span class="muted">{t.rateFromLabel}</span>
          <strong data-rate-min data-eur={t.rateMin.eur} data-usd={t.rateMin.usd}>{t.rateMin.eur}</strong>
          <span class="muted">{t.rateDownTo} <em data-rate-max data-eur={t.rateMax.eur} data-usd={t.rateMax.usd}>{t.rateMax.eur}</em></span>
        </div>
        <div class="pricing__processing">
          <span class="muted">{t.processingLabel}</span>
          <strong data-processing data-eur={t.processing.eur} data-usd={t.processing.usd}>{t.processing.eur}</strong>
          <span class="muted">{t.processingPer}</span>
        </div>
      </div>

      <div class="pricing__tiers" data-reveal-group>
        {
          eurTiers.map((tier, i) => (
            <div class:list={['tier', { 'tier--best': tier.best }]} data-reveal-item>
              <span class="tier__vol">
                <span class="tier__vol-val" data-eur={eurTiers[i].vol} data-usd={usdTiers[i].vol}>
                  {eurTiers[i].vol}
                </span>
                <small> {t.volSuffix}</small>
              </span>
              <span class="tier__rate" data-eur={eurTiers[i].fee} data-usd={usdTiers[i].fee}>
                {eurTiers[i].fee}
              </span>
              {tier.best && <span class="tier__badge">{t.bestBadge}</span>}
            </div>
          ))
        }
      </div>

      <p class="pricing__note muted">{t.note}</p>

      <div class="pricing__cta">
        <a href="#contact" class="btn btn--primary btn--lg" data-magnetic>{t.cta}</a>
        <span class="muted">{t.ctaNote}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing {
    overflow: hidden;
  }
  .pricing__head {
    text-align: center;
    max-width: 660px;
    margin: 0 auto clamp(2rem, 4vw, 3rem);
  }
  .pricing__head h2 {
    font-size: var(--fs-h2);
    margin-bottom: 1rem;
  }
  .pricing__head p {
    font-size: var(--fs-lead);
    max-width: 50ch;
    margin-inline: auto;
  }

  .pricing__toggle {
    position: relative;
    display: inline-flex;
    margin-top: 2rem;
    padding: 5px;
    border-radius: 999px;
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
  }
  .pricing__toggle button {
    position: relative;
    z-index: 1;
    padding: 0.6rem 1.6rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-300);
    transition: color 0.3s var(--ease-out);
  }
  .pricing__toggle button.is-active {
    color: var(--white);
  }
  .pricing__toggle-pill {
    position: absolute;
    z-index: 0;
    top: 5px;
    left: 5px;
    width: calc(50% - 5px);
    height: calc(100% - 10px);
    border-radius: 999px;
    background: linear-gradient(180deg, var(--indigo-500), var(--indigo-600));
    box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.4);
    transition: transform 0.4s var(--ease-out);
  }
  .pricing__toggle[data-cur='usd'] .pricing__toggle-pill {
    transform: translateX(100%);
  }

  .pricing__panel {
    max-width: 900px;
    margin-inline: auto;
    padding: clamp(1.6rem, 4vw, 2.8rem);
  }
  .pricing__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .pricing__rate,
  .pricing__processing {
    padding: 1.5rem;
    border-radius: var(--radius);
    background: var(--ink-950);
    border: 1px solid var(--border);
  }
  .pricing__rate {
    background: var(--ink-900);
    border: 1px solid var(--border);
    border-top: 2px solid var(--indigo-500);
  }
  .pricing__rate span,
  .pricing__processing span {
    display: block;
    font-size: 0.85rem;
  }
  .pricing__rate strong,
  .pricing__processing strong {
    display: block;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    color: var(--text-100);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0.2rem 0;
  }
  .pricing__rate em {
    font-style: normal;
    color: var(--indigo-300);
    font-weight: 600;
  }
  .pricing__processing strong {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    color: var(--text-200);
  }

  .pricing__tiers {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .tier {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem 1.4rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.3s var(--ease-out);
  }
  .tier:last-child {
    border-bottom: none;
  }
  .tier:hover {
    background: var(--surface);
  }
  .tier__vol {
    flex: 1;
    font-weight: 600;
    color: var(--text-200);
  }
  .tier__vol small {
    color: var(--text-400);
    font-weight: 400;
  }
  .tier__rate {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-100);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s var(--ease-out);
  }
  .tier--best {
    position: relative;
    background: var(--surface);
  }
  .tier--best::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--indigo-500);
  }
  .tier--best .tier__rate {
    color: var(--indigo-300);
  }
  .tier__badge {
    background: none;
    border: none;
    padding: 0;
    color: var(--indigo-300);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pricing__note {
    font-size: 0.85rem;
    margin-top: 1.5rem;
    line-height: 1.5;
  }
  .pricing__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.8rem;
  }
  .pricing__cta .muted {
    font-size: 0.88rem;
  }

  @media (max-width: 620px) {
    .pricing__hero {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLElement>('.pricing__toggle');
  const panel = document.querySelector<HTMLElement>('.pricing__panel');

  function setCurrency(cur: string) {
    if (!toggle || !panel) return;
    toggle.setAttribute('data-cur', cur);
    panel.setAttribute('data-cur', cur);
    toggle.querySelectorAll('button').forEach((b) => {
      const active = b.getAttribute('data-cur') === cur;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', String(active));
    });
    // Tous les éléments porteurs de data-eur / data-usd se mettent à jour.
    panel.querySelectorAll<HTMLElement>('[data-eur][data-usd]').forEach((el) => {
      const val = el.dataset[cur];
      if (val != null) el.textContent = val;
    });
  }

  toggle?.querySelectorAll('button').forEach((b) =>
    b.addEventListener('click', () => setCurrency(b.getAttribute('data-cur') || 'eur'))
  );
</script>
