---
import { ico } from '../icons';

interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  class?: string;
}
const { name, size = 20, strokeWidth = 1.75, class: className } = Astro.props;
const path = ico[name] ?? '';
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
  set:html={path}
></svg>
